{
  "open": {
    "post": {
      "summary": "Open Shift",
      "tags": ["Shifts"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "branch_id": { "type": "integer", "example": 1 },
                "starting_cash": { "type": "number", "example": 500000 }
              }
            }
          }
        }
      },
      "responses": { "200": { "$ref": "../responses/common.json#/GenericSuccess" } }
    }
  },
  "close": {
    "post": {
      "summary": "Close Shift",
      "tags": ["Shifts"],
      "security": [{"BearerAuth": []}],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "actual_cash": { "type": "number", "example": 1200000 }
              }
            }
          }
        }
      },
      "responses": { "200": { "$ref": "../responses/common.json#/GenericSuccess" } }
    }
  },
  "verify": {
    "patch": {
      "summary": "Verify Shift",
      "tags": ["Shifts"],
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
      "responses": { "200": { "$ref": "../responses/common.json#/GenericSuccess" } }
    }
  },
  "expenses": {
    "get": {
      "summary": "Get My Expenses for Current Shift",
      "tags": ["Shifts", "Expenses"],
      "security": [{"BearerAuth": []}],
      "responses": { "200": { "$ref": "../responses/common.json#/GenericSuccess" } }
    },
    "post": {
      "summary": "Record Expense for Current Shift",
      "tags": ["Shifts", "Expenses"],
      "security": [{"BearerAuth": []}],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "amount": { "type": "number", "example": 50000 },
                "description": { "type": "string", "example": "Beli es batu" }
              }
            }
          }
        }
      },
      "responses": { "201": { "$ref": "../responses/common.json#/GenericSuccess" } }
    }
  }
}
