{
    "init-offline-cart": {
    "post": {
      "summary": "Init Offline Cart (Cashier)",
      "tags": ["Sales"],
      "security": [{"BearerAuth": []}],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "../schemas/sales.json#/InitOfflineCartRequest" }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": { "$ref": "../schemas/sales.json#/Cart" }
                }
              }
            }
          }
        }
      }
    }
  },
  "carts": {
    "get": {
      "summary": "Get My Cart (Customer) / Get Offline Carts (Cashier)",
      "tags": ["Sales"],
      "security": [{"BearerAuth": []}],
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": { "$ref": "../schemas/sales.json#/Cart" }
                }
              }
            }
          }
        }
      }
    }
  },
  "cart-items": {
    "post": {
      "summary": "Add Item to Cart (Customer)",
      "tags": ["Sales"],
      "security": [{"BearerAuth": []}],
      "parameters": [
        {
          "name": "branch_id",
          "in": "query",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "../schemas/sales.json#/AddCartItemRequest" }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  },
  "cart-item-detail": {
    "post": {
      "summary": "Add Item to Offline Cart (Cashier)",
      "tags": ["Sales"],
      "security": [{"BearerAuth": []}],
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "../schemas/sales.json#/AddCartItemRequest" }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  },
  "transactions": {
    "post": {
      "summary": "Checkout (Customer/Cashier)",
      "tags": ["Sales"],
      "security": [{"BearerAuth": []}],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "../schemas/sales.json#/CheckoutRequest" }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": { "$ref": "../schemas/sales.json#/Transaction" }
                }
              }
            }
          }
        }
      }
    }
  },
  "transactions-list": {
    "get": {
      "summary": "Get Transactions (Supports Filters)",
      "tags": ["Sales"],
      "security": [{"BearerAuth": []}],
      "parameters": [
        { "name": "branch_id", "in": "query", "required": false, "schema": { "type": "integer" } },
        { "name": "status", "in": "query", "required": false, "schema": { "type": "string" } },
        { "name": "start_date", "in": "query", "required": false, "schema": { "type": "string" } },
        { "name": "end_date", "in": "query", "required": false, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": { "$ref": "../schemas/sales.json#/Transaction" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "transaction-detail": {
    "get": {
      "summary": "Get Transaction by ID",
      "tags": ["Sales"],
      "security": [{"BearerAuth": []}],
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": { "$ref": "../schemas/sales.json#/Transaction" }
                }
              }
            }
          }
        }
      }
    }
  },
  "transaction-status": {
    "patch": {
      "summary": "Update Transaction Status (Cashier/Manager)",
      "tags": ["Sales"],
      "security": [{"BearerAuth": []}],
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": { "$ref": "../schemas/sales.json#/UpdateTransactionStatusPayload" }
          }
        }
      },
      "responses": {
        "200": { "$ref": "../responses/common.json#/GenericSuccess" }
      }
    }
  }
}

