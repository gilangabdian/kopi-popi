{
  "/notifications": {
    "get": {
      "summary": "Get My Notifications",
      "description": "Ambil daftar notifikasi (In-App) milik user yang sedang login.",
      "tags": ["Notifications"],
      "security": [
        { "bearerAuth": [] }
      ],
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "example": {
                "status": "success",
                "message": "Notifications retrieved successfully",
                "data": [
                  {
                    "id": "e45a2781-a3f2-45e3-b461-123456789abc",
                    "user_id": "7b79d2b2-5f65-4d26-a084-fbbf61ab2f34",
                    "title": "Stok Menipis",
                    "message": "Stok Susu UHT sisa 2 Liter di Cabang 1",
                    "type": "WARNING",
                    "is_read": false,
                    "created_at": "2026-06-05T14:00:00Z"
                  }
                ]
              }
            }
          }
        }
      }
    }
  },
  "/notifications/{id}/read": {
    "put": {
      "summary": "Mark Notification as Read",
      "description": "Tandai sebuah notifikasi telah dibaca oleh user.",
      "tags": ["Notifications"],
      "security": [
        { "bearerAuth": [] }
      ],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "ID Notification",
          "schema": { "type": "string" }
        }
      ],
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "example": {
                "status": "success",
                "message": "Notification marked as read"
              }
            }
          }
        }
      }
    }
  }
}
