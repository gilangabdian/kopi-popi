{
  "sales": {
    "get": {
      "summary": "Get Sales Report (Admin/Manager)",
      "tags": ["Analytics"],
      "security": [{"BearerAuth": []}],
      "parameters": [
        { "name": "branch_id", "in": "query", "required": false, "schema": { "type": "integer" } },
        { "name": "start_date", "in": "query", "required": false, "schema": { "type": "string" } },
        { "name": "end_date", "in": "query", "required": false, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "date": { "type": "string" },
                        "total_revenue": { "type": "number" },
                        "total_transactions": { "type": "integer" },
                        "payment_breakdown": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "method": { "type": "string" },
                              "amount": { "type": "number" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "top-products": {
    "get": {
      "summary": "Get Top Products (Admin/Manager)",
      "tags": ["Analytics"],
      "security": [{"BearerAuth": []}],
      "parameters": [
        { "name": "branch_id", "in": "query", "required": false, "schema": { "type": "integer" } },
        { "name": "start_date", "in": "query", "required": false, "schema": { "type": "string" } },
        { "name": "end_date", "in": "query", "required": false, "schema": { "type": "string" } },
        { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer" } }
      ],
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "product_id": { "type": "integer" },
                        "product_name": { "type": "string" },
                        "total_quantity_sold": { "type": "integer" },
                        "total_revenue": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "shifts": {
    "get": {
      "summary": "Get Shift Reports (Admin/Manager)",
      "tags": ["Analytics"],
      "security": [{"BearerAuth": []}],
      "parameters": [
        { "name": "branch_id", "in": "query", "required": false, "schema": { "type": "integer" } },
        { "name": "start_date", "in": "query", "required": false, "schema": { "type": "string" } },
        { "name": "end_date", "in": "query", "required": false, "schema": { "type": "string" } }
      ],
      "responses": {
        "200": {
          "description": "Success",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "data": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "shift_id": { "type": "string" },
                        "cashier_name": { "type": "string" },
                        "branch_id": { "type": "integer" },
                        "start_time": { "type": "string" },
                        "end_time": { "type": "string" },
                        "expected_cash": { "type": "number" },
                        "actual_cash": { "type": "number" },
                        "difference": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
